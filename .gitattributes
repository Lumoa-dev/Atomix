* text=auto eol=lf
# Atomix 源码（文本，可 diff）
*.atx text diff
*.atxo text diff
# Atomix 编译产物（二进制，不可 diff）
*.atxe binary
# Rust 源码
*.rs text diff
# 文档
*.md text diff
*.svg text diff
*.toml text diff
*.json text diff
*.yaml text diff
*.yml text diff
*.csv text diff
# 图片（LFS）
*.png filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
